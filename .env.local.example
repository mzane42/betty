# Tennis Coach env config — copy to .env.local (gitignored) and fill in
# .env.local is loaded by Electron at runtime; never commit secrets.

# --- The Odds API ---------------------------------------------------------
# Free tier: 500 requests/month at https://the-odds-api.com
# Rotate via the dashboard whenever a key is exposed anywhere (chat, logs, screenshots).
ODDS_API_KEY=

# --- Telegram bot (optional) ----------------------------------------------
# From @BotFather. Whitelist user IDs (csv) to restrict who can interact.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# --- Betfair Exchange (optional, paid app key) ----------------------------
# Until set, Betfair-volume signal degrades to null (other signals carry the weight).
BETFAIR_APP_KEY=
BETFAIR_SESSION_TOKEN=

{
  "name": "poker-coach",
  "version": "0.1.0",
  "description": "Post-session poker analytics platform with bankroll focus",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "predev": "electron-rebuild -f -w better-sqlite3 || true",
    "dev": "electron-vite dev",
    "prebuild": "electron-rebuild -f -w better-sqlite3 || true",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "preimport": "npm rebuild better-sqlite3 --target_arch=arm64",
    "import": "tsx src/cli/import.ts",
    "prestats": "npm rebuild better-sqlite3 --target_arch=arm64",
    "stats": "tsx src/cli/stats.ts",
    "preleaks": "npm rebuild better-sqlite3 --target_arch=arm64",
    "leaks": "tsx src/cli/leaks.ts",
    "package": "electron-vite build && electron-builder",
    "package:mac": "electron-vite build && electron-builder --mac",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3 || true"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}

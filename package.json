{
  "name": "poker-coach",
  "version": "0.1.0",
  "description": "Post-session poker analytics platform with bankroll focus",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "predev": "electron-rebuild -f -w better-sqlite3 || true; rm -rf node_modules/node-pty/build 2>/dev/null; chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true",
    "dev": "electron-vite dev",
    "prebuild": "electron-rebuild -f -w better-sqlite3 || true; rm -rf node_modules/node-pty/build 2>/dev/null; chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "preimport": "npm rebuild better-sqlite3 --target_arch=arm64",
    "import": "tsx src/cli/import.ts",
    "prestats": "npm rebuild better-sqlite3 --target_arch=arm64",
    "stats": "tsx src/cli/stats.ts",
    "preleaks": "npm rebuild better-sqlite3 --target_arch=arm64",
    "leaks": "tsx src/cli/leaks.ts",
    "preequity": "npm rebuild better-sqlite3 --target_arch=arm64",
    "equity": "tsx src/cli/equity.ts",
    "precoach-brief": "npm rebuild better-sqlite3 --target_arch=arm64",
    "coach-brief": "tsx src/cli/coach-brief.ts",
    "coach": "./scripts/open-coach-terminal.sh",
    "package": "electron-vite build && electron-builder",
    "package:mac": "electron-vite build && electron-builder --mac",
    "rebuild": "electron-rebuild -f -w better-sqlite3 && electron-rebuild -f -w node-pty",
    "fix-pty-perms": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true",
    "postinstall": "electron-rebuild -f -w better-sqlite3 || true; rm -rf node_modules/node-pty/build 2>/dev/null; chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.16.0",
    "node-cron": "^4.2.1",
    "node-pty": "^1.1.0",
    "node-telegram-bot-api": "^0.67.0",
    "poker-odds": "^1.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}

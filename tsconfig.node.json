{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@main/*": ["src/main/*"],
      "@parser/*": ["src/parser/*"],
      "@db/*": ["src/db/*"],
      "@stats/*": ["src/stats/*"],
      "@reviewer/*": ["src/reviewer/*"],
      "@importer/*": ["src/importer/*"],
      "@types/*": ["src/types/*"],
      "@shared/*": ["src/shared/*"]
    },
    "types": ["node", "electron"]
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*",
    "src/parser/**/*",
    "src/db/**/*",
    "src/stats/**/*",
    "src/reviewer/**/*",
    "src/importer/**/*",
    "src/cli/**/*",
    "src/shared/**/*",
    "src/types/**/*",
    "src/tennis/**/*",
    "src/equity/**/*",
    "src/nash/**/*",
    "tests/**/*"
  ]
}
